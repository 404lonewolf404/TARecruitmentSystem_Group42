<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">
    
    <display-name>TA Recruitment System</display-name>
    <description>Teaching Assistant Recruitment and Management System</description>
    
    <!-- Welcome file list -->
    <welcome-file-list>
        <welcome-file>auth/login</welcome-file>
    </welcome-file-list>
    
    <!-- Session configuration -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/error.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/jsp/error.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/error.jsp</location>
    </error-page>
    
    <!-- Filters -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.bupt.tarecruitment.filter.AuthFilter</filter-class>
    </filter>
    
    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>com.bupt.tarecruitment.filter.RoleFilter</filter-class>
    </filter>
    
    <!-- Filter Mappings -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/ta/*</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/mo/*</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/ta/*</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/mo/*</url-pattern>
    </filter-mapping>
    
    <!-- Servlets -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.AuthServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>PositionServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.PositionServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>ApplicationServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.ApplicationServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.IndexServlet</servlet-class>
    </servlet>
    
    <!-- Servlet Mappings -->
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/auth/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>
    
    <!-- TA role mappings -->
    <servlet-mapping>
        <servlet-name>PositionServlet</servlet-name>
        <url-pattern>/ta/positions</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>PositionServlet</servlet-name>
        <url-pattern>/ta/positions/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ApplicationServlet</servlet-name>
        <url-pattern>/ta/applications</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ApplicationServlet</servlet-name>
        <url-pattern>/ta/applications/*</url-pattern>
    </servlet-mapping>
    
    <!-- MO role mappings -->
    <servlet-mapping>
        <servlet-name>PositionServlet</servlet-name>
        <url-pattern>/mo/positions</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>PositionServlet</servlet-name>
        <url-pattern>/mo/positions/*</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ApplicationServlet</servlet-name>
        <url-pattern>/mo/applications</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ApplicationServlet</servlet-name>
        <url-pattern>/mo/applications/*</url-pattern>
    </servlet-mapping>
    
</web-app>
